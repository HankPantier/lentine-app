# Supabase client config for the Expo app (iOS + Android + web).
# Copy to mobile/.env and fill in. Only EXPO_PUBLIC_* vars are exposed to the client bundle.
# The anon key is safe to embed in the client; it is NOT the service-role key.
# Get it from: Supabase dashboard → Project Settings → API → Project API keys → anon public.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
