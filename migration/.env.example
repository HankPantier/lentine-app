# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- Supabase (load stage) ---------------------------------------------------
# Use a STAGING project first (CLAUDE.md). The service-role key bypasses RLS — keep it secret.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Local MySQL (extract stage) ---------------------------------------------
# Defaults match docker-compose.yml; override only if the host port clashes.
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=wp
MYSQL_HOST_PORT=33061
